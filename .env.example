# Project / venv
VENV_DIR="$HOME/venv/openwebui-comfyui-flux2-editor"
COMFYUI_DIR="$(pwd)/vendor/ComfyUI"

# Network used by run.sh
HOST="0.0.0.0"
PORT="8188"

# ComfyUI I/O
COMFYUI_INPUT_DIR="$(pwd)/input"
COMFYUI_OUTPUT_DIR="$(pwd)/output"
COMFYUI_TEMP_DIR="$(pwd)/tmp"

# Hugging Face / model cache
HF_HOME="$(pwd)/.cache/huggingface"
TORCH_HOME="$(pwd)/.cache/torch"
HF_TOKEN=""

# CUDA / runtime
CUDA_VISIBLE_DEVICES="0"
PYTORCH_CUDA_ALLOC_CONF="expandable_segments:True"
CUDA_DEVICE_ORDER="PCI_BUS_ID"
NVIDIA_VISIBLE_DEVICES="all"

# Extra ComfyUI args examples:
# --cpu
# --disable-auto-launch
# --highvram
# --normalvram
# --lowvram
# --reserve-vram 8
# --preview-method auto
COMFYUI_EXTRA_ARGS="--disable-auto-launch"

# Torch override for special platforms (optional)
# TORCH_INDEX_URL="https://download.pytorch.org/whl/cu128"
# TORCH_PACKAGES="torch torchvision torchaudio"
# TORCH_WHL="https://.../torch-*.whl"
TORCH_INDEX_URL=""
TORCH_PACKAGES=""
TORCH_WHL=""
